{
  "name": "trailbase",
  "description": "Official TrailBase Client",
  "homepage": "https://trailbase.io",
  "version": "0.11.1",
  "license": "Apache-2.0 OR OSL-3.0",
  "type": "module",
  "main": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "default": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/trailbaseio/trailbase.git",
    "directory": "crates/assets/js/client"
  },
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit --skipLibCheck && eslint",
    "format": "prettier -w src tests",
    "prepack": "rm -rf ./dist && pnpm build && test -e ./dist/index.js",
    "test": "vitest run && vite-node tests/integration_test_runner.ts"
  },
  "dependencies": {
    "@types/geojson": "^7946.0.16",
    "@ungap/raw-json": "0.4.4",
    "geojson": "^0.5.0",
    "jwt-decode": "^4.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "http-status": "^2.1.0",
    "jsdom": "^29.0.1",
    "nano-spawn": "^2.0.0",
    "oauth2-mock-server": "^8.2.2",
    "otplib": "^13.4.0",
    "prettier": "^3.8.1",
    "tinybench": "^6.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vite-node": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.1"
  }
}
